"""
Stock Discovery Agent
- Ψάχνει νέες μετοχές από Buffett, Marks, Wood, Nash, Felix κλπ
- Τις αξιολογεί βάσει του στόχου σου
- Λέει πότε να αγοράσεις και πότε να πουλάς
- Τρέχει κάθε Δευτέρα 06:00 UTC
"""
import os, asyncio, aiohttp, json
from datetime import datetime

