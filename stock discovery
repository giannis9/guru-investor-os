CURRENCY    = "£"
GOAL        = float(os.getenv("GOAL_AMOUNT", "3000"))
GOAL_MONTHS = int(os.getenv("GOAL_MONTHS", "24"))
RISK_LEVEL  = os.getenv("RISK_LEVEL", "moderate")  # conservative/moderate/aggressive

# Μετοχές που ήδη έχεις — δεν θα τις ξανα-προτείνει
EXISTING = ["AMD", "RKLB", "PLTR", "MELI", "ASTS", "LSE", "VWCE", "LITE"]

# Guru universe — κάθε guru με το φιλοσοφικό του πλαίσιο
GURUS = {
    "Warren Buffett": {
        "style": "value investing, margin of safety, moat, long-term hold 5+ years",
        "favorites": ["AAPL","BRK.B","OXY","KO","AXP","BAC","CVX"],
